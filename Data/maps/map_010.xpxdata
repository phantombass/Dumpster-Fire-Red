    "8,26": {
      "id": 16,
      "name": "Dream Eater Tutor",
      "x": 8,
      "y": 26,
      "pages": [
        {
          "trigger": "Action Button",
          "condition_switch": null,
          "condition_switch_state": true,
          "condition_switch2": null,
          "condition_switch2_state": true,
          "condition_self_switch": null,
          "condition_variable_id": null,
          "condition_variable_value": 0,
          "condition_variable_operator": 1,
          "graphic_name": "NPC 06",
          "graphic": {
            "tile_id": 0,
            "character_name": "NPC 06",
            "character_hue": 0,
            "direction": 2,
            "pattern": 0,
            "opacity": 255,
            "blend_type": 0
          },
          "commands": [
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 0,
              "parameters": [
                "\\bYawn!\\nI must have dozed off in the sun."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 0,
              "parameters": [
                "\\bI had this weird dream about a Drowzee eating my "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 0,
              "parameters": [
                "dream."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 0,
              "parameters": [
                "\\bAnd...\\nI learned how to eat dreams..."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 0,
              "parameters": [
                "\\bOogh, this is too spooky!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 0,
              "parameters": [
                "\\bLet me teach it to a Pok\u00e9mon so I can forget about "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 0,
              "parameters": [
                "it!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 102,
              "indent": 0,
              "parameters": [
                [
                  "Yes",
                  "No"
                ],
                2
              ]
            },
            {
